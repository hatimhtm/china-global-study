# Supabase — Project → Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Auth gate — phrase users must type on /
# This is a soft localStorage gate, not real authentication.
# Set this to any non-empty string. If unset, login is disabled.
NEXT_PUBLIC_AUTH_PHRASE=your-secret-phrase
